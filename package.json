{
  "name": "gsp-release-tracker-dashboard",
  "version": "1.0.0",
  "description": "GSP Release Tracker — React Dashboard + API Server",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite --port 5174",
    "dev:server": "node --watch server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "heroku-postbuild": "vite build",
    "preview": "vite preview",
    "seed": "node server/seed.js",
    "start": "node server/index.js",
    "sync": "node scripts/sync-local.js",
    "sync:confluence": "node scripts/sync-confluence.js",
    "sync:confluence:local": "node scripts/confluence-ingest-local.mjs",
    "sync:confluence:merge-push": "node scripts/confluence-local-merge-push.mjs",
    "sync:all": "node scripts/sync-local.js && node scripts/sync-confluence.js",
    "test": "vitest run",
    "test:nl-smoke": "node scripts/smoke-nl-queries.mjs",
    "db:monday-status": "node scripts/monday-data-status.mjs",
    "db:purge-jira": "node scripts/db-purge-jira.mjs",
    "db:purge-jira:dry": "node scripts/db-purge-jira.mjs --dry-run",
    "heroku:setup:glip": "bash scripts/heroku-setup-glip.sh"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "lucide-react": "^0.383.0",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
