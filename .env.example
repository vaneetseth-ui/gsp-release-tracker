# Copy to `.env` for local dev (`.env` is gitignored).
# Production (Heroku): after `heroku login`, run `npm run heroku:setup:glip` or
#   ./scripts/heroku-setup-glip.sh YOUR_APP_NAME
# If `heroku config:set` says "Couldn't find that app", the git remote is stale — the script fixes it.
# RingCentral → Glip / team messaging incoming webhook URL.
GLIP_WEBHOOK_URL=

# Primary runtime / ingest settings.
DATABASE_URL=
INGEST_TOKEN=
HEROKU_URL=https://gsp-release-tracker-ffa0c1ec9485.herokuapp.com

# Monday.com authoritative source-of-truth ingest.
MONDAY_API_KEY=
MONDAY_API_VERSION=2026-04
MONDAY_BOARD_PRIORITIES_ID=18396681774
MONDAY_BOARD_TRACKER_1_ID=18399812494
MONDAY_BOARD_TRACKER_2_ID=18399616718

# Jira supplement.
JIRA_URL=https://jira.ringcentral.com
JIRA_PAT=
